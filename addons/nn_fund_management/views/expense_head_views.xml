<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_expense_head_tree" model="ir.ui.view">
        <field name="name">nn.expense.head.tree</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <tree string="Expense Heads">
                <field name="name"/>
                <field name="code"/>
                <field name="total_allocated" sum="Allocated"/>
                <field name="requisition_hold" sum="Req. Hold"/>
                <field name="transfer_hold" sum="Transfer Hold"/>
                <field name="total_spent" sum="Spent"/>
                <field name="available_fund" sum="Available"/>
                <field name="currency_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_expense_head_form" model="ir.ui.view">
        <field name="name">nn.expense.head.form</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <form string="Expense Head">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_allocations" type="object"
                                class="oe_stat_button" icon="fa-share-alt">
                            <field name="allocation_count" widget="statinfo"
                                   string="Allocations"/>
                        </button>
                        <button name="action_view_requisitions" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <field name="requisition_count" widget="statinfo"
                                   string="Requisitions"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Office Rent"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Balances">
                        <group>
                            <field name="total_allocated"/>
                            <field name="incoming_transfer"/>
                            <field name="outgoing_transfer"/>
                            <field name="total_spent"/>
                        </group>
                        <group>
                            <field name="requisition_hold"/>
                            <field name="transfer_hold"/>
                            <field name="approved_unspent"/>
                            <field name="available_fund"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_expense_head" model="ir.actions.act_window">
        <field name="name">Expense Heads</field>
        <field name="res_model">nn.expense.head</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
