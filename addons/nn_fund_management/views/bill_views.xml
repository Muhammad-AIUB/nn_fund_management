<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bill_tree" model="ir.ui.view">
        <field name="name">nn.bill.tree</field>
        <field name="model">nn.bill</field>
        <field name="arch" type="xml">
            <tree string="Bills">
                <field name="name"/>
                <field name="bill_date"/>
                <field name="requisition_id"/>
                <field name="project_id" optional="show"/>
                <field name="expense_head_id" optional="show"/>
                <field name="partner_id" optional="hide"/>
                <field name="amount" sum="Amount"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'posted'"
                       decoration-muted="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <record id="view_bill_form" model="ir.ui.view">
        <field name="name">nn.bill.form</field>
        <field name="model">nn.bill</field>
        <field name="arch" type="xml">
            <form string="Bill">
                <header>
                    <button name="action_post" type="object" string="Post"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state == 'cancelled'"
                            confirm="Cancelling a posted bill returns the amount to the requisition. Continue?"/>
                    <button name="action_reset_to_draft" type="object"
                            string="Reset to Draft"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,posted"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="requisition_id"
                                   readonly="state != 'draft'"/>
                            <field name="requisition_remaining"/>
                            <field name="target_type"/>
                            <field name="project_id"
                                   invisible="target_type != 'project'"/>
                            <field name="expense_head_id"
                                   invisible="target_type != 'expense_head'"/>
                        </group>
                        <group>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="bill_date" readonly="state != 'draft'"/>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="reference" readonly="state != 'draft'"/>
                            <field name="currency_id" column_invisible="1"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" nolabel="1"/>
                        </page>
                        <page string="Attachments" name="attachments">
                            <field name="attachment_ids"
                                   widget="many2many_binary" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_bill" model="ir.actions.act_window">
        <field name="name">Bills</field>
        <field name="res_model">nn.bill</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
