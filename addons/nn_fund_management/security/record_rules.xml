<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Multi-company record rules: a user can only see records of the
         companies they are allowed into. These are global rules (apply to
         every user) and complement the group ACLs and the server-side
         permission checks in the approval workflow. -->

    <record id="rule_fund_account_company" model="ir.rule">
        <field name="name">Fund Account: multi-company</field>
        <field name="model_id" ref="model_nn_fund_account"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
    </record>

